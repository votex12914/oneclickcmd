#!/usr/bin/env bash
# ==========================================================
#  RDP Installer рџљЂ
#  SUBSCRIBE TO AyushtheWarrior
# ==========================================================

set -euo pipefail

# ---------------- ANSI COLORS (SAFE) ----------------
G=$'\033[32m'
B=$'\033[34m'
Y=$'\033[33m'
R=$'\033[31m'
C=$'\033[36m'
W=$'\033[97m'
N=$'\033[0m'

# ---------------- ROOT CHECK ----------------
if [[ "$EUID" -ne 0 ]]; then
  printf "%b\n" "${R}вќЊ Please run with sudo${N}"
  exit 1
fi

USER_NAME="${SUDO_USER:-root}"
USER_HOME="$(eval echo ~${USER_NAME})"

# ---------------- UTIL FUNCTIONS ----------------
divider() {
  printf "%b\n" "${B}==============================================================${N}"
}

typewriter() {
  local text="$1"
  local delay="${2:-0.015}"
  for ((i=0; i<${#text}; i++)); do
    printf "%s" "${text:i:1}"
    sleep "$delay"
  done
  printf "\n"
}

spinner() {
  local pid=$!
  local frames='в ‹в ™в №в ёв јв ґв ¦в §в ‡в Џ'
  while kill -0 "$pid" 2>/dev/null; do
    for ((i=0;i<${#frames};i++)); do
      printf "\r%b" "${C}${frames:i:1} Working...${N}"
      sleep 0.08
    done
  done
  printf "\r%b\n" "${G}вњ” Done${N}"
}

progress_bar() {
  local percent=$1 width=40
  local filled=$((percent*width/100))
  local empty=$((width-filled))
  printf "%b[" "${Y}"
  printf "%0.sв–€" $(seq 1 "$filled")
  printf "%0.sв–‘" $(seq 1 "$empty")
  printf "] %d%%%b\n" "$percent" "${N}"
}

run_step() {
  local label="$1"; shift
  printf "%b\n" "${G}рџ”№ ${label}${N}"
  ( "$@" ) & spinner
}

# ---------------- INTRO ----------------
clear
printf "%b\n" "${C}"
cat <<'EOF'
__     ______  _______ _______ __   __ 
\ \   / / __ \|__   __|__   __|\ \ / / 
 \ \ / / |  | |  | |     | |    \ V /  
  \ V /| |  | |  | |     | |     | |   
   | | | |__| |  | |     | |     | |   
   |_|  \____/   |_|     |_|     |_|   
         By AyushTheWarrior X VOTEX
EOF
printf "%b\n" "${N}"

divider
printf "%b" "${W}"; typewriter "рџљЂ RDP Installer"; printf "%b" "${N}"
printf "%b" "${Y}"; typewriter "SUBSCRIBE TO Sagar Gaming 2X"; printf "%b" "${N}"
divider
sleep 0.6

# ---------------- SYSTEM CHECK ----------------
RAM_MB=$(awk '/MemTotal/ {print int($2/1024)}' /proc/meminfo)
printf "%b\n" "${B}рџ§  RAM Detected: ${RAM_MB} MB${N}"
if [[ "$RAM_MB" -lt 2000 ]]; then
  printf "%b\n" "${Y}вљ пёЏ Low RAM detected вЂ” optimized defaults enabled${N}"
fi
sleep 0.4

# ---------------- STEPS ----------------
STEP=0; TOTAL=8
step() {
  STEP=$((STEP+1))
  local percent=$((STEP*100/TOTAL))
  printf "%b\n" "${W}вћЎпёЏ  Step ${STEP}/${TOTAL}${N}"
  progress_bar "$percent"
}

step
run_step "Updating system" apt update -y

step
run_step "Upgrading packages" apt upgrade -y

step
run_step "Installing XFCE & XRDP" apt install -y xfce4 xfce4-goodies xrdp

step
run_step "Installing Firefox ESR" apt install -y firefox-esr

step
printf "%b\n" "${G}рџ”№ Configuring XFCE session${N}"
(
  printf "startxfce4\n" > "${USER_HOME}/.xsession"
  chown "${USER_NAME}:${USER_NAME}" "${USER_HOME}/.xsession"
) & spinner

step
printf "%b\n" "${G}рџ”№ Enabling XRDP service${N}"
(systemctl enable xrdp && systemctl restart xrdp) & spinner

step
printf "%b\n" "${G}рџ”№ Applying XRDP black-screen fix${N}"
(
  sed -i.bak 's/^test -x/#test -x/' /etc/xrdp/startwm.sh || true
  {
    printf "unset DBUS_SESSION_BUS_ADDRESS\n"
    printf "unset XDG_RUNTIME_DIR\n"
  } >> /etc/xrdp/startwm.sh
  systemctl restart xrdp
) & spinner

step
printf "%b\n" "${G}рџ”№ Firewall: allowing RDP (3389)${N}"
(
  if command -v ufw >/dev/null 2>&1; then
    ufw allow 3389/tcp
    ufw reload
  else
    printf "UFW not installed вЂ” skipped\n"
  fi
) & spinner

# ---------------- FINISH ----------------
divider
printf "%b" "${G}"; typewriter "вњ… Installation Completed Successfully!"; printf "%b" "${N}"
printf "%b" "${Y}"; typewriter "рџ’» Connect via RDP в†’ Port 3389"; printf "%b" "${N}"
printf "%b" "${G}"; typewriter "рџ”Ґ Powered by CodesHub"; printf "%b" "${N}"
divider
